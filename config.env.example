# =============================================================================
# Lab configuration — copy to `config.env` and edit to override the defaults.
# =============================================================================
# Every variable below has a sensible default baked into deploy.sh and
# run-tests.sh. config.env is therefore OPTIONAL: the lab works out of the
# box without it. Use this file when you want to pin a different version,
# resize the gateway, or run the lab against a different cluster name without
# editing the scripts.
#
# Workflow:
#   cp config.env.example config.env
#   # edit config.env (gitignored; never committed)
#   ./deploy.sh
#   ./run-tests.sh

# --- Cluster -----------------------------------------------------------------

# k3d cluster name. The Kubernetes context is derived as `k3d-${CLUSTER_NAME}`.
CLUSTER_NAME=igw-tc-lab

# Host port the k3d load-balancer maps to the gateway's port 80, for
# manual `curl localhost:${IGW_HTTP_PORT}/get` and browser access from
# outside the k3d cluster. The lab's load generators (fortio, h2dial,
# ghz) run inside the cluster and hit the in-cluster Service URL on
# port 80, so this host-side port doesn't affect any test result.
# Bumped above the common 8080 to avoid conflicts with other local
# clusters running concurrently.
IGW_HTTP_PORT=18080

# --- Pinned component versions -----------------------------------------------

# Solo Enterprise for Istio version. The lab is validated against 1.27.x;
# minor-version drift across 1.27 should be safe. Major bumps may require
# adjustments to istioctl flags or `proxyStatsMatcher` syntax.
ISTIO_VERSION=1.27.8

# Kubernetes Gateway API CRDs (required for the waypoint resource).
GATEWAY_API_VERSION=v1.2.1

# kube-prometheus-stack Helm chart version. Update via:
#   curl -sL https://prometheus-community.github.io/helm-charts/index.yaml \
#     | python3 -c "import yaml,sys;print(yaml.safe_load(sys.stdin)['entries']['kube-prometheus-stack'][0]['version'])"
KUBE_PROM_STACK_VERSION=84.5.0

# --- Load-generator container images -----------------------------------------

# fortio is version-tagged. Its queue-on-cap behavior is load-bearing for
# scenarios 02-fortio through 05-fortio; an upstream change to dial-on-cap
# would silently invalidate those scenarios. Pin defensively.
FORTIO_IMAGE=fortio/fortio:1.75.1

# grpcbin is digest-pinned because the upstream maintainer hasn't pushed a
# versioned tag since 2022. The digest below is what was :latest at the
# time the lab was validated against it.
GRPCBIN_IMAGE=moul/grpcbin@sha256:bd8f2ffdd02d0849fad2d1c754eff4402c867e7a3e0552b8992f4590f5687d20

# Grafana admin password. The local cluster is transient and never
# exposed, so this is a convenience credential, not a secret.
#
# IMPORTANT: do NOT set this to the literal string "admin". Grafana 9.5+
# detects an admin user whose password equals the default "admin" and
# forces a password change on first UI login. That breaks shared
# human+automation access: as soon as someone opens the dashboard and
# is forced to change the password, Basic-auth calls from run-tests.sh
# (the renderer screenshot path) start returning 302 -> /login.
#
# Picking anything other than "admin" skips the forced-change check.
# We also pass [security] disable_initial_admin_password_change=true to
# Grafana via Helm so the prompt is suppressed regardless.
GRAFANA_ADMIN_PASSWORD=lab-igw

# Grafana image renderer for auto-screenshots during run-tests.sh. The
# image is amd64-only; deploy.sh pulls it with --platform=linux/amd64
# so it works on Apple Silicon (under Rosetta) and on Linux amd64
# (natively). Update by checking
#   curl -s 'https://hub.docker.com/v2/repositories/grafana/grafana-image-renderer/tags?page_size=10&ordering=last_updated'
# (tag scheme is `vMAJOR.MINOR.PATCH`).
#
# Tag form ONLY: deploy.sh splits this on `:` to set helm flags
# (grafana.imageRenderer.image.repository and .tag separately). A digest
# pin like `grafana/grafana-image-renderer@sha256:...` would parse
# incorrectly. If you need digest pinning, set the helm flags directly
# and skip the parser.
RENDERER_IMAGE=grafana/grafana-image-renderer:v5.8.3

# --- Gateway sizing ----------------------------------------------------------

# Number of istio-ingressgateway pods. 6 gives enough kube-proxy hashing
# surface to make the "few connections among many pods" regime cleanly
# observable. Less than 4 makes coefficient-of-variation noisy.
IGW_REPLICAS=6

# CPU limit per IGW pod, AND the number of Envoy worker threads per pod.
# deploy.sh derives `meshConfig.defaultConfig.concurrency` from IGW_CPU,
# so this is the single source of truth for both. Keep at 1 to run the
# lab's default 16-scenario suite; set IGW_CPU=2+ to enable scenario 13
# (within-pod connection balance via `connection_balance_config`), which
# brings the suite to all 17. Higher values fit less comfortably on a
# typical local k3d cluster alongside ztunnel/grafana, so don't go past
# 2 unless you have headroom. Redeploy after changing.
IGW_CPU=1

# Number of waypoint replicas (scenarios 6 and 7). Single-replica makes
# coefficient-of-variation undefined; 3+ is recommended for the
# mechanism-transfer test.
WAYPOINT_REPLICAS=3

# --- Scenario timing ---------------------------------------------------------
# Each scenario runs the load gen twice: a warmup (results discarded) and
# a measure run (results captured). Both phases use the values below.
# Longer measure runs reduce variance; shorter warmups speed up iteration.
# Values are Go-style duration strings (`15s`, `2m`, `90s`, etc.).

# Warmup duration: long enough to populate caches, prime connection pools,
# and let HPAs / autoscalers settle.
SCENARIO_WARMUP_DURATION=15s

# Measure duration: long enough to produce statistically meaningful
# results. 60s is the lab default; 120s+ is recommended if you're
# comparing scenarios where the effect size is small.
SCENARIO_MEASURE_DURATION=60s
