# =============================================================================
# Lab configuration — copy to `config.env` and edit to override the defaults.
# =============================================================================
# Every variable below has a sensible default baked into deploy.sh and
# run-tests.sh. config.env is therefore OPTIONAL: the lab works out of the
# box without it. Use this file when you want to pin a different version,
# resize the gateway, or run the lab against a different cluster name without
# editing the scripts.
#
# Workflow:
#   cp config.env.example config.env
#   # edit config.env (gitignored; never committed)
#   ./deploy.sh
#   ./run-tests.sh

# --- Cluster -----------------------------------------------------------------

# k3d cluster name. The Kubernetes context is derived as `k3d-${CLUSTER_NAME}`.
CLUSTER_NAME=igw-tc-lab

# Host port the gateway listens on. Bumped above the common 8080 to avoid
# conflicts with other local clusters running concurrently.
IGW_HTTP_PORT=18080

# --- Pinned component versions -----------------------------------------------

# Solo Enterprise for Istio version. The lab is validated against 1.27.x;
# minor-version drift across 1.27 should be safe. Major bumps may require
# adjustments to istioctl flags or `proxyStatsMatcher` syntax.
ISTIO_VERSION=1.27.8

# Kubernetes Gateway API CRDs (required for the waypoint resource).
GATEWAY_API_VERSION=v1.2.1

# kube-prometheus-stack Helm chart version. Update via:
#   curl -sL https://prometheus-community.github.io/helm-charts/index.yaml \
#     | python3 -c "import yaml,sys;print(yaml.safe_load(sys.stdin)['entries']['kube-prometheus-stack'][0]['version'])"
KUBE_PROM_STACK_VERSION=84.5.0

# --- Load-generator container images -----------------------------------------

# fortio is version-tagged. Its queue-on-cap behavior is load-bearing for
# scenarios 02-fortio through 05-fortio; an upstream change to dial-on-cap
# would silently invalidate those scenarios. Pin defensively.
FORTIO_IMAGE=fortio/fortio:1.75.1

# grpcbin is digest-pinned because the upstream maintainer hasn't pushed a
# versioned tag since 2022. The digest below is what was :latest at the
# time the lab was validated against it.
GRPCBIN_IMAGE=moul/grpcbin@sha256:bd8f2ffdd02d0849fad2d1c754eff4402c867e7a3e0552b8992f4590f5687d20

# --- Gateway sizing ----------------------------------------------------------

# Number of istio-ingressgateway pods. 6 gives enough kube-proxy hashing
# surface to make the "few connections among many pods" regime cleanly
# observable. Less than 4 makes coefficient-of-variation noisy.
IGW_REPLICAS=6

# CPU limit per IGW pod. With Envoy concurrency pinned to 1
# (values.global.proxy.concurrency=1, set in deploy.sh), this also
# determines the per-pod worker thread count. Keeping this at 1 lets 6
# replicas fit on a typical local k3d cluster alongside ztunnel/grafana.
IGW_CPU=1

# Number of waypoint replicas (scenarios 6 and 7). Single-replica makes
# coefficient-of-variation undefined; 3+ is recommended for the
# mechanism-transfer test.
WAYPOINT_REPLICAS=3
